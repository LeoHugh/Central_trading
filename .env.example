# ========== Server ==========
PORT=8082

# ========== MySQL ==========
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=central_trading

# ========== Kafka ==========
KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=central-trading
KAFKA_GROUP_ID=central-trading-group

# Topic overrides (defaults match KAFKA_CONTRACT)
# KAFKA_TOPIC_ORDER_COMMAND=central.order.command
# KAFKA_TOPIC_CANCEL_COMMAND=central.cancel.command
# KAFKA_TOPIC_STOCK_QUERY=central.stock.query
# KAFKA_TOPIC_STOCK_QUOTE=client.stock.quote
# KAFKA_TOPIC_TRADE_REPORT=client.trade.report
# KAFKA_TOPIC_ORDER_REPORT=client.order.report

# ========== External Services ==========
# Account sub-system base URL
ACCOUNT_API_BASE=http://localhost:8080
# Set to true to use mock responses when account system is unavailable
ACCOUNT_API_MOCK=true

# ========== Trading Hours ==========
TRADING_START_HOUR=9
TRADING_START_MINUTE=30
TRADING_END_HOUR=15
TRADING_END_MINUTE=0
